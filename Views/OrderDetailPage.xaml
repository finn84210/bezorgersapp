<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="bezorgersapp.Views.OrderDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Ritdetails"
    Shell.NavBarIsVisible="False">

    <ScrollView BackgroundColor="#F3F4F6">
        <VerticalStackLayout Padding="18" Spacing="16">
            <Grid ColumnDefinitions="64,*,64" HeightRequest="58">
                <Button
                    BackgroundColor="#FFFFFF"
                    BorderColor="#111827"
                    BorderWidth="1"
                    Clicked="BackTapped"
                    CornerRadius="8"
                    Text="Terug"
                    TextColor="#111827" />
                <Label
                    Grid.Column="1"
                    FontAttributes="Bold"
                    FontSize="28"
                    HorizontalTextAlignment="Center"
                    Text="Ritdetails"
                    VerticalTextAlignment="Center" />
            </Grid>

            <Border Padding="16" BackgroundColor="#FFFFFF" Stroke="#111827" StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="8">
                    <Label FontAttributes="Bold" FontSize="20" Text="Aflevering" />
                    <Label FontAttributes="Bold" FontSize="24" Text="{Binding Order.Address}" />
                    <Label FontSize="17" Text="{Binding Order.PostalCode, StringFormat='{0} Amsterdam'}" />
                    <Label FontSize="15" Text="{Binding Order.CustomerName, StringFormat='Klant: {0}'}" />
                    <Label FontSize="15" Text="{Binding Order.Notes, StringFormat='Opmerking: {0}'}" />
                    <Button
                        Margin="0,8,0,0"
                        BackgroundColor="#111827"
                        Command="{Binding OpenMapsCommand}"
                        CornerRadius="8"
                        Text="Route openen in Google Maps"
                        TextColor="White" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="16" BackgroundColor="#FFFFFF" Stroke="#111827" StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="8">
                    <Label FontAttributes="Bold" FontSize="20" Text="Businformatie" />
                    <Label Text="{Binding Order.VanName, StringFormat='Bus: {0}'}" />
                    <Label Text="{Binding Order.VanLicensePlate, StringFormat='Kenteken: {0}'}" />
                    <Label Text="{Binding Order.VanLoadingZone, StringFormat='Laadplek: {0}'}" />
                    <Label Text="{Binding Order.VanFuelLevel, StringFormat='Brandstof: {0}'}" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="16" BackgroundColor="#FFFFFF" Stroke="#111827" StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="10">
                    <Label FontAttributes="Bold" FontSize="20" Text="Pakketten controleren" />
                    <Label Text="{Binding PackageCheckText}" />
                    <CollectionView ItemsSource="{Binding Order.Packages}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,6" ColumnDefinitions="42,*">
                                    <CheckBox
                                        IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                        CheckedChanged="PackageCheckedChanged" />
                                    <Label
                                        Grid.Column="1"
                                        Text="{Binding Description}"
                                        VerticalTextAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border Padding="16" BackgroundColor="#FFFFFF" Stroke="#111827" StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="12">
                    <Label FontAttributes="Bold" FontSize="20" Text="Status en bewijs" />
                    <Picker
                        FontSize="17"
                        ItemsSource="{Binding StatusOptions}"
                        SelectedItem="{Binding SelectedStatus}" />
                    <Button
                        BackgroundColor="#111827"
                        Command="{Binding UpdateStatusCommand}"
                        CornerRadius="8"
                        Text="Status opslaan"
                        TextColor="White" />

                    <Button
                        BackgroundColor="#FFFFFF"
                        BorderColor="#111827"
                        BorderWidth="1"
                        Command="{Binding GetLocationCommand}"
                        CornerRadius="8"
                        Text="GPS-locatie ophalen"
                        TextColor="#111827" />
                    <Label FontSize="15" Text="{Binding LocationText}" />

                    <Button
                        BackgroundColor="#FFFFFF"
                        BorderColor="#111827"
                        BorderWidth="1"
                        Command="{Binding TakePhotoCommand}"
                        CornerRadius="8"
                        Text="Foto maken als bewijs"
                        TextColor="#111827" />
                    <Image
                        Aspect="AspectFill"
                        BackgroundColor="#E5E7EB"
                        HeightRequest="160"
                        Source="{Binding DeliveryPhoto}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
