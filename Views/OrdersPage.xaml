<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="bezorgersapp.Views.OrdersPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Taken"
    Shell.NavBarIsVisible="False">

    <Grid BackgroundColor="#F3F4F6" RowDefinitions="Auto,*">
        <VerticalStackLayout Padding="20,18,20,12" Spacing="4">
            <Label
                FontAttributes="Bold"
                FontSize="30"
                Text="Demo ritten" />
            <Label
                FontSize="15"
                Text="Bestellingen die klaarstaan voor de bezorgapp."
                TextColor="#4B5563" />
        </VerticalStackLayout>

        <RefreshView
            Grid.Row="1"
            Command="{Binding LoadOrdersCommand}"
            IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Orders}" Margin="20,0,20,18">
                <CollectionView.EmptyView>
                    <Border
                        Margin="0,20,0,0"
                        Padding="18"
                        BackgroundColor="#FFFFFF"
                        Stroke="#111827"
                        StrokeShape="RoundRectangle 8">
                        <Label
                            FontSize="16"
                            HorizontalTextAlignment="Center"
                            Text="{Binding Message}"
                            TextColor="#4B5563" />
                    </Border>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,0,0,14"
                            Padding="16"
                            BackgroundColor="#FFFFFF"
                            Stroke="#111827"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8">
                            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">
                                <Grid ColumnDefinitions="42,*,Auto" ColumnSpacing="12">
                                    <Border
                                        BackgroundColor="#111827"
                                        HeightRequest="36"
                                        Stroke="#111827"
                                        StrokeShape="RoundRectangle 18"
                                        WidthRequest="36">
                                        <Label
                                            FontAttributes="Bold"
                                            HorizontalTextAlignment="Center"
                                            Text="{Binding Id}"
                                            TextColor="White"
                                            VerticalTextAlignment="Center" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="21"
                                            LineBreakMode="TailTruncation"
                                            Text="{Binding Address}" />
                                        <Label
                                            FontSize="15"
                                            Text="{Binding FullAddress}"
                                            TextColor="#4B5563" />
                                    </VerticalStackLayout>

                                    <Button
                                        Grid.Column="2"
                                        BackgroundColor="#FFFFFF"
                                        BorderColor="#111827"
                                        BorderWidth="1"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenOrderCommand}"
                                        CommandParameter="{Binding .}"
                                        CornerRadius="8"
                                        FontSize="14"
                                        Padding="12,8"
                                        Text="Details"
                                        TextColor="#111827" />
                                </Grid>

                                <Border
                                    Grid.Row="1"
                                    Padding="10,6"
                                    BackgroundColor="#F9FAFB"
                                    Stroke="#D1D5DB"
                                    StrokeShape="RoundRectangle 8">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="13"
                                        Text="{Binding Status}"
                                        TextColor="#111827" />
                                </Border>

                                <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="12">
                                    <VerticalStackLayout Spacing="3">
                                        <Label FontSize="12" Text="Pakketten" TextColor="#6B7280" />
                                        <Label FontAttributes="Bold" FontSize="16" Text="{Binding PackageSize}" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" Spacing="3">
                                        <Label FontSize="12" Text="Bus" TextColor="#6B7280" />
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="16"
                                            Text="{Binding VanLicensePlate}" />
                                        <Label
                                            FontSize="13"
                                            Text="{Binding VanLoadingZone}"
                                            TextColor="#4B5563" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
