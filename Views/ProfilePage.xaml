<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="bezorgersapp.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Profiel"
    Shell.NavBarIsVisible="False">

    <VerticalStackLayout Padding="22" Spacing="18">
        <Grid ColumnDefinitions="48,*,48" HeightRequest="58">
            <Label FontSize="16" Text="Menu" VerticalTextAlignment="Center" />
            <Label
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="30"
                HorizontalTextAlignment="Center"
                Text="Profiel"
                VerticalTextAlignment="Center" />
            <Label Grid.Column="2" FontSize="28" HorizontalTextAlignment="Center" Text="!" />
        </Grid>

        <Border
            Padding="20"
            BackgroundColor="#FFFFFF"
            Stroke="#111827"
            StrokeShape="RoundRectangle 8">
            <VerticalStackLayout Spacing="14" HorizontalOptions="Center">
                <Label FontSize="60" HorizontalTextAlignment="Center" Text="( )" />
                <Label FontAttributes="Bold" FontSize="24" HorizontalTextAlignment="Center" Text="Bezorger" />
                <Label FontSize="18" HorizontalTextAlignment="Center" Text="Matrix Inc." />
                <Label FontSize="16" HorizontalTextAlignment="Center" Text="Vandaag actief: 8u 43m" />
            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>
</ContentPage>
